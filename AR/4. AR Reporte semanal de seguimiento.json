      "parameters": {
        "jsCode": "let mensaje = `⚠️ Reporte semanal de onboarding pendientes\n\nTotal clientes pendientes: ${items.length}\n\n`;\n\nfor (const item of items) {\n\n  mensaje += `🔹 ${item.json.cliente}\nPlan: ${item.json.plan}\nPendiente hace ${item.json.diasPendiente} días\n${item.json.url}\n\n`;\n}\n\nreturn [{\n  json: {\n    reporte: mensaje\n  }\n}];"
      },
