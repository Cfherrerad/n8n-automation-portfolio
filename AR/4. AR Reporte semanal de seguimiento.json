        "jsCode": "const ahora = Date.now();\n\nreturn items.map(item => {\n\n  const fechaCreacion = Number(item.json.date_created);\n\n  const diasPendiente = Math.floor(\n    (ahora - fechaCreacion) / (1000 * 60 * 60 * 24)\n  );\n\n  return {\n    json: {\n      cliente: item.json.name,\n      plan: item.json.list.name,\n      estado: item.json.status.status,\n      diasPendiente,\n      url: item.json.url\n    }\n  };\n});"
