    {
      "parameters": {
        "sendTo": "={{ $('Ventas Google Sheets Trigger').item.json.Email }}",
        "subject": "🚀 ¡Tu Plan Growth ya está en marcha!",
        "message": "={{\n`\n<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Plan Growth Activado</title>\n</head>\n<body style=\"font-family: Arial, Helvetica, sans-serif; background-color: #f4f6f8; margin: 0; padding: 20px;\">\n\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width: 650px; margin: auto; background-color: #ffffff; border-radius: 10px; overflow: hidden;\">\n\n        <tr>\n            <td style=\"background-color: #2563eb; padding: 25px; color: white; text-align: center;\">\n                <h1 style=\"margin: 0;\">🚀 ¡Plan Growth Activado!</h1>\n            </td>\n        </tr>\n\n        <tr>\n            <td style=\"padding: 30px; color: #333333; line-height: 1.6;\">\n\n                <p>\n                    Hola <strong>${\n                        $('Ventas Google Sheets Trigger').first().json.Nombres\n                    } ${\n                        $('Ventas Google Sheets Trigger').first().json.Apellidos\n                    }</strong>,\n                </p>\n\n                <p>\n                    ¡Excelente noticia! Tu plan <strong>Growth</strong> acaba de activarse y ya estamos trabajando para impulsar tus resultados. 🚀\n                </p>\n\n                <p>\n                    En esta etapa vamos a analizar tus procesos actuales, identificar oportunidades de automatización y definir juntos los próximos hitos de tu estrategia.\n                </p>\n\n                <p>\n                    Para avanzar, completa el siguiente brief de inicio:\n                </p>\n\n                <p style=\"text-align: center; margin: 30px 0;\">\n                    <a href=\"https://tally.so/r/0QkW60\"\n                       style=\"background-color: #2563eb; color: white; text-decoration: none; padding: 14px 24px; border-radius: 6px; display: inline-block;\">\n                        👉 Completar Brief Growth\n                    </a>\n                </p>\n\n                <p>\n                    Este documento nos ayudará a entender tus métricas, herramientas actuales y prioridades para comenzar con la configuración del plan.\n                </p>\n\n                <p>\n                    Una vez completado, te contactaremos para agendar una reunión de arranque y presentarte el flujo de trabajo adaptado a tu negocio.\n                </p>\n\n                <p>\n                    ¡Gracias por seguir creciendo con nosotros!\n                </p>\n\n                <br>\n\n                <p>\n                    💼 <strong>El equipo de Agencia Roca</strong>\n                </p>\n\n            </td>\n        </tr>\n\n        <tr>\n            <td style=\"background-color: #f3f4f6; color: #6b7280; text-align: center; padding: 15px; font-size: 12px;\">\n                Este correo fue enviado automáticamente por nuestro sistema de onboarding.\n            </td>\n        </tr>\n\n    </table>\n\n</body>\n</html>\n`\n}}\n",
        "options": {}
      },
